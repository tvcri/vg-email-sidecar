# Database Configuration
# Must match Village Green API database
DB_HOST=localhost
DB_PORT=3306
DB_USER=vg_user
DB_PASSWORD=your_password_here
DB_NAME=vg

# Gmail Configuration
# Path to the service-account key JSON (client_email, private_key). The SA has
# domain-wide delegation for gmail.send and impersonates the sending mailbox.
GMAIL_SA_KEY_PATH=./vg-mailer-sa-key.json

# Poll Configuration
# Interval in milliseconds between email event polls (default: 60000 = 60 seconds)
POLL_INTERVAL_MS=60000

# Logging
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Testing
# TEST_RECIPIENTS: Optional override for all email recipients (for testing only).
# When set, ALL emails—both new_request and patch_request—will be sent to these
# addresses only, regardless of the real volunteer list. This prevents test emails
# from being sent to actual volunteers and helps conserve Gmail API quota.
#
# Set to a comma-separated list of email addresses. Example:
#   TEST_RECIPIENTS=csmig@csmig.com,tester@csmig.com
#

# PIN Webhook (API → sidecar)
# Shared secret for POST /internal/send-pin. The API attaches it as
# `Authorization: Bearer <value>`; the sidecar verifies it constant-time before
# emailing the PIN. Set the IDENTICAL value here and in the API's
# VG_ENROLL_SIDECAR_KEY. If unset, the sidecar rejects ALL send-pin requests
# with 401 (fail-closed). Optional HTTP_PORT (default 8125) / HTTP_HOST
# (default 127.0.0.1) tune the listener.
VG_ENROLL_SIDECAR_KEY=

# Listener bind address (default: 127.0.0.1). Keep the localhost default when
# the API and sidecar run on the same host. Only widen this if the API calls
# from another host, and if you do, ensure VG_ENROLL_SIDECAR_KEY is set to a
# strong secret and restrict access at the network layer (firewall). Prefer
# binding to a specific internal NIC address (e.g. 10.0.1.5) over 0.0.0.0.
#HTTP_HOST=127.0.0.1

# Listener port (default: 8125).
#HTTP_PORT=8125
