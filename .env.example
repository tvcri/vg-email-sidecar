# Database Configuration
# Must match Village Green API database
DB_HOST=localhost
DB_PORT=3306
DB_USER=vg_user
DB_PASSWORD=your_password_here
DB_NAME=vg

# Gmail Configuration
# Path to the service-account key JSON (client_email, private_key). The SA has
# domain-wide delegation for gmail.send and impersonates the sending mailbox.
GMAIL_SA_KEY_PATH=./vg-mailer-sa-key.json

# Poll Configuration
# Interval in milliseconds between email event polls (default: 60000 = 60 seconds)
POLL_INTERVAL_MS=60000

# Logging
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Testing
# TEST_RECIPIENTS: Optional override for all email recipients (for testing only).
# When set, ALL emails—both new_request and patch_request—will be sent to these
# addresses only, regardless of the real volunteer list. This prevents test emails
# from being sent to actual volunteers and helps conserve Gmail API quota.
#
# Set to a comma-separated list of email addresses. Example:
#   TEST_RECIPIENTS=csmig@csmig.com,tester@csmig.com
#
